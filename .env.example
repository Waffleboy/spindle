# ── LLM ───────────────────────────────────────────────
LLM_MODEL=anthropic/claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# Override litellm endpoint and API key (optional)
# LITELLM_API_BASE=https://your-proxy.example.com
# LITELLM_API_KEY=sk-...

# ── Database ──────────────────────────────────────────
# DATABASE_URL=sqlite:///data/taxonomy.db

# ── Directories ───────────────────────────────────────
# DATA_DIR=data
# ORIGINALS_DIR=data/originals

# ── Ingestion ─────────────────────────────────────────
# PDF_RENDER_DPI=150
# WORD_CHARS_PER_PAGE=3000

# ── Chunking ──────────────────────────────────────────
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
# WORDS_PER_PAGE=300

# ── Chat ──────────────────────────────────────────────
# CHAT_HISTORY_LIMIT=10
# SEMANTIC_SEARCH_TOP_K=5

# ── Server ────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000